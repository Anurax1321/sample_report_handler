# CORS Configuration
CORS_ORIGINS=http://localhost:5175

# Database Configuration (PostgreSQL)
SQLALCHEMY_DATABASE_URI=postgresql://sample_user:sample_pass@localhost:5434/sample_report_db

# JWT Secret (random per restart if not set)
JWT_SECRET_KEY=your-secret-key

# Token expiration (minutes)
ACCESS_TOKEN_EXPIRE_MINUTES=480

# For Docker (db is the service name):
# SQLALCHEMY_DATABASE_URI=postgresql://sample_user:sample_pass@db:5432/sample_report_db
